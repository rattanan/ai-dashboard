DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
CREDENTIAL_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
DATA_SOURCE_ENCRYPTION_KEY="optional-dedicated-base64-encoded-32-byte-key"
CREDENTIAL_KEY_VERSION="env-v1"
APP_URL="http://localhost:3000"
OBJECT_STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH=".data/uploads"
MAX_EXCEL_UPLOAD_BYTES="10485760"
MAX_EXCEL_IMPORT_ROWS="100000"
MAX_EXCEL_SHEETS="50"
LOG_LEVEL="info"
AI_PROVIDER="openai-compatible"
AI_BASE_URL="http://localhost:8000/v1"
AI_API_KEY="replace-with-provider-api-key"
AI_MODEL="replace-with-provider-model-id"
AI_SUPPORTS_JSON_SCHEMA="true"
AI_TIMEOUT_MS="300000"
AI_STREAM_INACTIVITY_TIMEOUT_MS="60000"
AI_MAX_RETRIES="2"
AI_TEMPERATURE="0.1"
AI_MAX_TABLES="30"
AI_MAX_COLUMNS_PER_TABLE="80"
AI_SAMPLE_ROWS_PER_TABLE="5"
AI_MAX_SAMPLE_CELL_LENGTH="200"
AI_MAX_CONTEXT_CHARACTERS="120000"
AI_SEND_SAMPLE_DATA="true"
AI_MASK_SENSITIVE_DATA="true"
AI_MAX_KPI_RECOMMENDATIONS="12"
AI_MAX_WIDGETS="12"
AI_MAX_INSIGHTS="8"
QUERY_TIMEOUT_MS="10000"
QUERY_MAX_ROWS="1000"
QUERY_PREVIEW_ROWS="100"
INITIAL_ADMIN_NAME="System Administrator"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES="30"
PASSWORD_RESET_DELIVERY_URL="https://notifications.example.com/password-reset"
PASSWORD_RESET_DELIVERY_TOKEN="replace-with-notification-service-token"
MAX_FAILED_LOGIN_ATTEMPTS="5"
ACCOUNT_LOCK_DURATION_MINUTES="30"
LOGIN_RATE_LIMIT_WINDOW_MINUTES="15"
LOGIN_RATE_LIMIT_MAX_ATTEMPTS="20"
SEED_DEVELOPMENT_TEST_USERS="false"
DEVELOPMENT_TEST_USER_PASSWORD="replace-with-a-development-only-password"
