DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"
CREDENTIAL_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
CREDENTIAL_KEY_VERSION="env-v1"
APP_URL="http://localhost:3000"
OBJECT_STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH=".data/uploads"
MAX_EXCEL_UPLOAD_BYTES="10485760"
LOG_LEVEL="info"
AI_PROVIDER="openai-compatible"
AI_BASE_URL="http://localhost:8000/v1"
AI_API_KEY="replace-with-provider-api-key"
AI_MODEL="replace-with-provider-model-id"
AI_SUPPORTS_JSON_SCHEMA="true"
AI_TIMEOUT_MS="60000"
AI_MAX_RETRIES="2"
AI_TEMPERATURE="0.1"
AI_MAX_TABLES="30"
AI_MAX_COLUMNS_PER_TABLE="80"
AI_SAMPLE_ROWS_PER_TABLE="5"
AI_MAX_SAMPLE_CELL_LENGTH="200"
AI_MAX_CONTEXT_CHARACTERS="120000"
AI_SEND_SAMPLE_DATA="true"
AI_MASK_SENSITIVE_DATA="true"
AI_MAX_KPI_RECOMMENDATIONS="12"
AI_MAX_WIDGETS="12"
AI_MAX_INSIGHTS="8"
QUERY_TIMEOUT_MS="10000"
QUERY_MAX_ROWS="1000"
QUERY_PREVIEW_ROWS="100"
